{
  "name": "dcentrica/silverstripe-redis-cache",
  "description": "Enables Redis cache for Silverstripe",
  "type": "silverstripe-vendormodule",
  "homepage": "https://github.com/dcentrica/silverstripe-redis-cache",
  "keywords": [
      "silverstripe",
      "redis",
      "valkey",
      "cache"
  ],
  "license": "BSD-3-Clause",
  "support": {
      "issues": "https://github.com/dcentrica/silverstripe-redis-cache/issues"
  },
  "authors": [
      {
          "name": "Philipp Staender",
          "email": "pstaender@mailbox.org"
      },
      {
          "name": "Michael Houghton",
          "email": "michael.houghton@oireachtas.ie"
      }
  ],
  "require": {
      "silverstripe/framework": "^5 || ^6",
      "predis/predis": "^3.4"
  },
  "require-dev": {
      "phpunit/phpunit": "~9.5"
  },
  "autoload": {
      "psr-4": {
          "Zeitpulse\\": "src/",
          "Zeitpulse\\Tests": "tests/"
      }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "silverstripe/vendor-plugin": true
    }
  }
}
